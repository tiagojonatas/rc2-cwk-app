<%
  const pageTitle = "Editar Cliente";
  const activeMenu = "clients";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<section class="max-w-3xl rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
  <form method="POST" action="/clients/<%= clientData.id %>/edit" class="grid gap-4 md:grid-cols-2">
    <label class="text-sm text-gray-600">
      Nome
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="name" value="<%= clientData.name %>" required />
    </label>

    <label class="text-sm text-gray-600">
      Empresa
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="company_name" value="<%= clientData.company_name || '' %>" />
    </label>

    <label class="text-sm text-gray-600">
      Telefone
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="phone" value="<%= clientData.phone || '' %>" />
    </label>

    <label class="text-sm text-gray-600">
      Email
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="email" name="email" value="<%= clientData.email || '' %>" />
    </label>

    <label class="text-sm text-gray-600">
      Plano
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="plan" value="<%= clientData.plan || '' %>" />
    </label>

    <label class="text-sm text-gray-600">
      Mensalidade
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="number" step="0.01" min="0" name="monthly_value" value="<%= Number(clientData.monthly_value || 0) %>" />
    </label>

    <label class="text-sm text-gray-600 md:col-span-2">
      Status
      <select class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" name="status">
        <option value="active" <%= clientData.status === 'active' ? 'selected' : '' %>>active</option>
        <option value="inactive" <%= clientData.status === 'inactive' ? 'selected' : '' %>>inactive</option>
      </select>
    </label>

    <div class="mt-2 flex items-center gap-3 md:col-span-2">
      <button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" type="submit">Atualizar</button>
      <a class="text-sm text-gray-600 hover:underline" href="/clients">Voltar</a>
    </div>
  </form>
</section>

<%- include("../partials/footer") %>
