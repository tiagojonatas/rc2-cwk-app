<%
  const pageTitle = "Clientes";
  const activeMenu = "clients";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<div class="mb-4 flex justify-end">
  <a class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" href="/clients/create">Novo Cliente</a>
</div>

<section class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-100">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Nome</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Empresa</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Telefone</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Email</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Plano</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Mensalidade</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% if (clients.length === 0) { %>
          <tr>
            <td class="px-4 py-4 text-sm text-gray-500" colspan="8">Nenhum cliente cadastrado.</td>
          </tr>
        <% } %>

        <% clients.forEach((client) => { %>
          <tr>
            <td class="px-4 py-4">
              <p class="text-sm font-medium text-gray-900"><%= client.name %></p>
              <p class="mt-0.5 text-sm text-gray-500"><%= client.company_name || "-" %></p>
            </td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= client.company_name || "-" %></td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= client.phone || "-" %></td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= client.email || "-" %></td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= client.plan || "-" %></td>
            <td class="px-4 py-4 text-base font-semibold text-gray-900">R$ <%= Number(client.monthly_value || 0).toFixed(2) %></td>
            <td class="px-4 py-4 text-sm">
              <% if (["inactive", "inativo"].includes(String(client.status || "").toLowerCase())) { %>
                <span class="inline-flex rounded-full bg-gray-100 px-2 py-1 text-xs font-medium tracking-wide text-gray-600">Inativo</span>
              <% } else { %>
                <span class="inline-flex rounded-full bg-green-100 px-2 py-1 text-xs font-medium tracking-wide text-green-700">Ativo</span>
              <% } %>
            </td>
            <td class="px-4 py-4 text-sm">
              <a class="inline-flex rounded-lg px-2.5 py-1.5 text-sm font-medium text-indigo-600 transition-all duration-200 hover:bg-indigo-50 hover:text-indigo-700" href="/clients/<%= client.id %>/edit">Editar</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/footer") %>
