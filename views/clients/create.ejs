<%
  const pageTitle = "Novo Cliente";
  const activeMenu = "clients";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<section class="max-w-3xl rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-100 md:p-8">
  <div class="mb-6 border-b border-gray-100 pb-4">
    <h3 class="text-lg font-semibold tracking-tight text-slate-900">Cadastro de cliente</h3>
    <p class="mt-1 text-sm text-gray-500">Preencha os dados para adicionar um novo cliente.</p>
  </div>

  <form method="POST" action="/clients/create" class="grid gap-5 md:grid-cols-2">
    <label class="text-sm font-medium text-slate-700">
      Nome
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="text" name="name" placeholder="Digite o nome do cliente" required />
    </label>

    <label class="text-sm font-medium text-slate-700">
      Empresa
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="text" name="company_name" placeholder="Nome da empresa (opcional)" />
    </label>

    <label class="text-sm font-medium text-slate-700">
      Telefone
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="text" name="phone" placeholder="(00) 00000-0000" />
    </label>

    <label class="text-sm font-medium text-slate-700">
      Email
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="email" name="email" placeholder="cliente@empresa.com" />
    </label>

    <label class="text-sm font-medium text-slate-700">
      Plano
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="text" name="plan" placeholder="Ex: Sala fixa, Hot desk..." />
    </label>

    <label class="text-sm font-medium text-slate-700">
      Mensalidade
      <input class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" type="number" step="0.01" min="0" name="monthly_value" value="0" />
    </label>

    <label class="text-sm font-medium text-slate-700 md:col-span-2">
      Status
      <select class="mt-1 w-full rounded-xl border border-gray-300 bg-white px-3.5 py-2.5 text-sm text-slate-800 shadow-sm outline-none transition-all duration-200 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20" name="status">
        <option value="active">Ativo</option>
        <option value="inactive">Inativo</option>
      </select>
    </label>

    <div class="mt-2 flex items-center gap-3 md:col-span-2">
      <button class="rounded-xl bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md" type="submit">Salvar cliente</button>
      <a class="text-sm font-medium text-slate-600 transition-colors duration-200 hover:text-slate-900 hover:underline" href="/clients">Voltar</a>
    </div>
  </form>
</section>

<%- include("../partials/footer") %>
