<%
  const pageTitle = "Novo Usuario";
  const activeMenu = "users";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<section class="max-w-3xl rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
  <form method="POST" action="/users/create" class="grid gap-4 md:grid-cols-2">
    <label class="text-sm text-gray-600">
      Nome
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="name" required />
    </label>
    <label class="text-sm text-gray-600">
      Email
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="email" name="email" required />
    </label>
    <label class="text-sm text-gray-600">
      Senha
      <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="text" name="password" required />
    </label>
    <label class="text-sm text-gray-600">
      Role
      <select class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" name="role" required>
        <% allowedRoles.forEach((role) => { %>
          <option value="<%= role %>"><%= role %></option>
        <% }) %>
      </select>
    </label>

    <div class="mt-2 flex items-center gap-3 md:col-span-2">
      <button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" type="submit">Salvar</button>
      <a class="text-sm text-gray-600 hover:underline" href="/users">Voltar</a>
    </div>
  </form>
</section>

<%- include("../partials/footer") %>
