<%
  const pageTitle = "Usuários";
  const activeMenu = "users";

  function roleLabel(role) {
    const labels = {
      admin: "Administrador",
      manager: "Gestor",
      funcionario: "Funcionário",
      client: "Cliente",
    };
    return labels[role] || role;
  }

  function roleBadgeClass(role) {
    const classes = {
      admin: "bg-indigo-50 text-indigo-700 ring-indigo-200",
      manager: "bg-blue-50 text-blue-700 ring-blue-200",
      funcionario: "bg-amber-50 text-amber-700 ring-amber-200",
      client: "bg-slate-100 text-slate-700 ring-slate-200",
    };
    return classes[role] || "bg-slate-100 text-slate-700 ring-slate-200";
  }
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<section class="space-y-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h3 class="font-display-modern text-xl font-semibold text-slate-900 md:text-2xl">Gestão de usuários</h3>
      <p class="mt-1 text-sm font-medium text-slate-500">Gerencie perfis de acesso e status dos usuários do sistema.</p>
    </div>
    <a class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-indigo-600 to-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md" href="/users/create">
      Novo usuário
    </a>
  </div>

  <div class="space-y-2">
    <% if (error) { %>
      <p class="rounded-xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm text-red-700"><%= error %></p>
    <% } %>
    <% if (success) { %>
      <p class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-2.5 text-sm text-emerald-700"><%= success %></p>
    <% } %>
  </div>

  <section class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
    <div class="border-b border-gray-100 px-5 py-4 sm:px-6">
      <p class="text-sm font-medium text-slate-700">Usuários cadastrados: <span class="font-semibold text-slate-900"><%= users.length %></span></p>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-slate-50/80">
          <tr>
            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:px-6">Nome</th>
            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:px-6">E-mail</th>
            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:px-6">Perfil</th>
            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:px-6">Status</th>
            <th class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:px-6">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% if (users.length === 0) { %>
            <tr>
              <td class="px-5 py-6 text-sm text-slate-500 sm:px-6" colspan="5">Nenhum usuário cadastrado.</td>
            </tr>
          <% } %>

          <% users.forEach((user) => { %>
            <tr class="transition-colors duration-200 hover:bg-slate-50/80">
              <td class="px-5 py-4 sm:px-6">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-600">
                    <%= (user.name || "U").charAt(0).toUpperCase() %>
                  </span>
                  <span class="text-sm font-medium text-slate-800"><%= user.name %></span>
                </div>
              </td>
              <td class="px-5 py-4 text-sm text-slate-700 sm:px-6"><%= user.email %></td>
              <td class="px-5 py-4 text-sm sm:px-6">
                <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= roleBadgeClass(user.role) %>"><%= roleLabel(user.role) %></span>
              </td>
              <td class="px-5 py-4 text-sm sm:px-6">
                <% if (user.status === "inativo") { %>
                  <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">Inativo</span>
                <% } else { %>
                  <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200">Ativo</span>
                <% } %>
              </td>
              <td class="px-5 py-4 text-sm sm:px-6">
                <div class="flex flex-wrap items-center gap-2.5">
                  <a class="rounded-lg border border-slate-200 px-2.5 py-1.5 text-xs font-medium text-slate-700 transition-colors duration-200 hover:bg-slate-100" href="/users/<%= user.id %>/edit">Editar</a>
                  <% if (user.status === "inativo") { %>
                    <form method="POST" action="/users/<%= user.id %>/activate">
                      <button type="submit" class="rounded-lg border border-emerald-200 bg-emerald-50 px-2.5 py-1.5 text-xs font-semibold text-emerald-700 transition-colors duration-200 hover:bg-emerald-100">Ativar</button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/users/<%= user.id %>/deactivate">
                      <button type="submit" class="rounded-lg border border-red-200 bg-red-50 px-2.5 py-1.5 text-xs font-semibold text-red-700 transition-colors duration-200 hover:bg-red-100">Desativar</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</section>

<%- include("../partials/footer") %>
