<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu, topbarDate }) %>

<section class="mb-6 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100">
  <form method="GET" action="/reports" class="flex flex-col gap-3 sm:flex-row sm:items-end">
    <label class="app-label normal-case text-gray-500">
      M&ecirc;s de refer&ecirc;ncia
      <select name="month" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 sm:w-64">
        <% monthOptions.forEach((item) => { %>
          <option value="<%= item.value %>" <%= item.value === selectedMonth ? "selected" : "" %>><%= item.label %></option>
        <% }) %>
      </select>
    </label>
    <button class="cursor-pointer rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-all duration-200 hover:bg-indigo-700 hover:shadow-md" type="submit">
      Atualizar
    </button>
  </form>
</section>

<section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="app-label">Receita do m&ecirc;s</p>
    <h3 class="mt-2 text-3xl font-semibold text-emerald-600"><%= revenue.paidMonth %></h3>
    <% if (bookings && bookings.revenueFromBookings) { %>
      <p class="mt-2 text-sm text-gray-500">Receita (reservas): <span class="font-semibold text-slate-800"><%= bookings.revenueFromBookings %></span></p>
    <% } %>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="app-label">Pendente total</p>
    <h3 class="mt-2 text-3xl font-semibold text-red-600"><%= revenue.pendingTotal %></h3>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="app-label">Clientes ativos</p>
    <h3 class="mt-2 text-3xl font-semibold text-slate-900"><%= clients.active %></h3>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="app-label">Clientes em atraso</p>
    <h3 class="mt-2 text-3xl font-semibold text-red-600"><%= delinquency.overdueClients %></h3>
  </article>
</section>

<section class="mt-8 grid gap-6 xl:grid-cols-2">
  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="app-section-title">Receita</h3>
    <p class="app-description mt-1">Resumo simples de faturamento</p>

    <div class="mt-4 space-y-2 text-sm">
      <p class="text-gray-500">Receita total do m&ecirc;s: <span class="text-base font-semibold text-emerald-600"><%= revenue.paidMonth %></span></p>
      <p class="text-gray-500">Total pendente: <span class="text-base font-semibold text-red-600"><%= revenue.pendingTotal %></span></p>
    </div>

    <h4 class="app-label mt-5">&Uacute;ltimos 3 meses</h4>
    <ul class="mt-2 space-y-2">
      <% if (revenue.last3Months.length === 0) { %>
        <li class="text-sm text-gray-500">Sem registros de receita.</li>
      <% } %>
      <% revenue.last3Months.forEach((item) => { %>
        <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
          <span class="text-sm text-gray-500"><%= item.refMonth %></span>
          <span class="font-semibold text-slate-800"><%= item.total %></span>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="app-section-title">Clientes</h3>
    <p class="app-description mt-1">Base de clientes no per&iacute;odo atual</p>

    <ul class="mt-4 space-y-3 text-sm">
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-sm text-gray-500">Total de clientes ativos</span>
        <span class="font-semibold text-emerald-600"><%= clients.active %></span>
      </li>
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-sm text-gray-500">Clientes novos no m&ecirc;s</span>
        <span class="font-semibold text-indigo-600"><%= clients.newInMonth %></span>
      </li>
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-sm text-gray-500">Clientes inativos</span>
        <span class="font-semibold text-red-600"><%= clients.inactive %></span>
      </li>
    </ul>
  </article>
</section>

<section class="mt-8 grid gap-6 xl:grid-cols-2">
  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="app-section-title">Salas</h3>
    <p class="app-description mt-1">Total de reservas no m&ecirc;s por sala</p>

    <ul class="mt-4 space-y-3">
      <% if (roomsMonthUsage.length === 0) { %>
        <li class="text-sm text-gray-500">Nenhuma sala cadastrada.</li>
      <% } %>
      <% roomsMonthUsage.forEach((room) => { %>
        <li class="rounded-lg px-3 py-2 <%= room.isTopRoom ? 'border border-emerald-200 bg-emerald-50' : 'bg-gray-50' %>">
          <div class="flex items-center justify-between text-sm">
            <div>
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-900"><%= room.name %></span>
                <% if (room.isTopRoom) { %>
                  <span class="rounded-full bg-emerald-100 px-2 py-1 text-[10px] font-medium tracking-wide text-emerald-700">Mais utilizada</span>
                <% } %>
              </div>
              <div class="text-xs text-gray-500 mt-1">Ocupação (tempo): <%= room.percent %>% — <%= Math.floor(room.minutes/60) %>h <%= room.minutes % 60 %>m</div>
            </div>
            <div class="text-right">
              <div class="font-semibold text-slate-800"><%= room.bookings_count %> reservas</div>
            </div>
          </div>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="app-section-title">Inadimpl&ecirc;ncia</h3>
    <p class="app-description mt-1">Pend&ecirc;ncias financeiras em aberto</p>

    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 p-4">
      <p class="text-sm font-medium text-red-700">Total em atraso</p>
      <p class="text-2xl font-semibold text-red-700"><%= delinquency.totalOverdue %></p>
      <p class="mt-1 text-xs font-medium tracking-wide text-red-600"><%= delinquency.overdueClients %> cliente(s) em atraso</p>
    </div>

    <ul class="mt-4 space-y-2">
      <% if (delinquency.list.length === 0) { %>
        <li class="text-sm text-gray-500">Nenhum cliente em atraso.</li>
      <% } %>
      <% delinquency.list.forEach((item) => { %>
        <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
          <span class="text-sm font-medium text-gray-900"><%= item.client_name %></span>
          <span class="font-semibold text-red-600"><%= item.total_due %></span>
        </li>
      <% }) %>
    </ul>
  </article>
</section>

<%- include("../partials/footer") %>

