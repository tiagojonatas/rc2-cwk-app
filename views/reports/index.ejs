<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu, topbarDate }) %>

<section class="mb-6 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100">
  <form method="GET" action="/reports" class="flex flex-col gap-3 sm:flex-row sm:items-end">
    <label class="text-sm text-gray-600">
      Mes de referencia
      <select name="month" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 sm:w-64">
        <% monthOptions.forEach((item) => { %>
          <option value="<%= item.value %>" <%= item.value === selectedMonth ? "selected" : "" %>><%= item.label %></option>
        <% }) %>
      </select>
    </label>
    <button class="cursor-pointer rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white transition-all duration-200 hover:bg-indigo-700 hover:shadow-md" type="submit">
      Atualizar
    </button>
  </form>
</section>

<section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Receita do mes</p>
    <h3 class="mt-2 text-3xl font-semibold text-emerald-600"><%= revenue.paidMonth %></h3>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Pendente total</p>
    <h3 class="mt-2 text-3xl font-semibold text-red-600"><%= revenue.pendingTotal %></h3>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Clientes ativos</p>
    <h3 class="mt-2 text-3xl font-semibold text-slate-900"><%= clients.active %></h3>
  </article>
  <article class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Clientes em atraso</p>
    <h3 class="mt-2 text-3xl font-semibold text-red-600"><%= delinquency.overdueClients %></h3>
  </article>
</section>

<section class="mt-8 grid gap-6 xl:grid-cols-2">
  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="text-lg font-semibold text-slate-900">Receita</h3>
    <p class="mt-1 text-sm text-gray-500">Resumo simples de faturamento</p>

    <div class="mt-4 space-y-2 text-sm">
      <p class="text-gray-700">Receita total do mes: <span class="font-semibold text-emerald-600"><%= revenue.paidMonth %></span></p>
      <p class="text-gray-700">Total pendente: <span class="font-semibold text-red-600"><%= revenue.pendingTotal %></span></p>
    </div>

    <h4 class="mt-5 text-sm font-semibold uppercase tracking-wide text-gray-500">Ultimos 3 meses</h4>
    <ul class="mt-2 space-y-2">
      <% if (revenue.last3Months.length === 0) { %>
        <li class="text-sm text-gray-500">Sem registros de receita.</li>
      <% } %>
      <% revenue.last3Months.forEach((item) => { %>
        <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
          <span class="text-gray-600"><%= item.refMonth %></span>
          <span class="font-semibold text-slate-800"><%= item.total %></span>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="text-lg font-semibold text-slate-900">Clientes</h3>
    <p class="mt-1 text-sm text-gray-500">Base de clientes no periodo atual</p>

    <ul class="mt-4 space-y-3 text-sm">
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-gray-600">Total de clientes ativos</span>
        <span class="font-semibold text-emerald-600"><%= clients.active %></span>
      </li>
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-gray-600">Clientes novos no mes</span>
        <span class="font-semibold text-indigo-600"><%= clients.newInMonth %></span>
      </li>
      <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2">
        <span class="text-gray-600">Clientes inativos</span>
        <span class="font-semibold text-red-600"><%= clients.inactive %></span>
      </li>
    </ul>
  </article>
</section>

<section class="mt-8 grid gap-6 xl:grid-cols-2">
  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="text-lg font-semibold text-slate-900">Salas</h3>
    <p class="mt-1 text-sm text-gray-500">Total de reservas no mes por sala</p>

    <ul class="mt-4 space-y-3">
      <% if (roomsMonthUsage.length === 0) { %>
        <li class="text-sm text-gray-500">Nenhuma sala cadastrada.</li>
      <% } %>
      <% roomsMonthUsage.forEach((room) => { %>
        <li class="rounded-lg px-3 py-2 <%= room.isTopRoom ? 'border border-emerald-200 bg-emerald-50' : 'bg-gray-50' %>">
          <div class="flex items-center justify-between text-sm">
            <div class="flex items-center gap-2">
              <span class="font-medium text-slate-700"><%= room.name %></span>
              <% if (room.isTopRoom) { %>
                <span class="rounded-full bg-emerald-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-emerald-700">Mais utilizada</span>
              <% } %>
            </div>
            <span class="font-semibold text-slate-800"><%= room.bookings_count %> reservas</span>
          </div>
        </li>
      <% }) %>
    </ul>
  </article>

  <article class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
    <h3 class="text-lg font-semibold text-slate-900">Inadimplencia</h3>
    <p class="mt-1 text-sm text-gray-500">Pendencias financeiras em aberto</p>

    <div class="mt-4 rounded-lg border border-red-200 bg-red-50 p-4">
      <p class="text-sm text-red-700">Total em atraso</p>
      <p class="text-2xl font-semibold text-red-700"><%= delinquency.totalOverdue %></p>
      <p class="mt-1 text-xs text-red-600"><%= delinquency.overdueClients %> cliente(s) em atraso</p>
    </div>

    <ul class="mt-4 space-y-2">
      <% if (delinquency.list.length === 0) { %>
        <li class="text-sm text-gray-500">Nenhum cliente em atraso.</li>
      <% } %>
      <% delinquency.list.forEach((item) => { %>
        <li class="flex items-center justify-between rounded-lg bg-gray-50 px-3 py-2 text-sm">
          <span class="text-gray-700"><%= item.client_name %></span>
          <span class="font-semibold text-red-600"><%= item.total_due %></span>
        </li>
      <% }) %>
    </ul>
  </article>
</section>

<%- include("../partials/footer") %>
