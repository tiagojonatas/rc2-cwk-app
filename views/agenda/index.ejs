<%
  const pageTitle = "Agenda";
  const activeMenu = "agenda";
  const topbarDate = currentDateLabel;
  const topbarActionLink = "/agenda/nova";
  const topbarActionLabel = "+ Nova reserva";

  function statusView(status) {
    if (status === "confirmed") {
      return { label: "Confirmada", badge: "bg-emerald-100 text-emerald-700" };
    }
    if (status === "cancelled_by_admin" || status === "cancelled_by_client" || status === "cancelado") {
      return { label: "Cancelada", badge: "bg-red-100 text-red-700" };
    }
    if (status === "no_show") {
      return { label: "No-show", badge: "bg-slate-200 text-slate-700" };
    }
    return { label: "Pendente", badge: "bg-amber-100 text-amber-700" };
  }

  const now = new Date();
  const todayStr = now.toISOString().slice(0, 10);
  const startOfWeek = new Date(now);
  startOfWeek.setHours(0, 0, 0, 0);
  startOfWeek.setDate(now.getDate() - now.getDay());

  const weekDays = [];
  const dayFormatter = new Intl.DateTimeFormat("pt-BR", { weekday: "short" });

  for (let i = 0; i < 7; i += 1) {
    const date = new Date(startOfWeek);
    date.setDate(startOfWeek.getDate() + i);
    const iso = date.toISOString().slice(0, 10);
    const dayBookings = (bookings || []).filter((booking) => booking.date === iso);

    weekDays.push({
      iso,
      dayLabel: dayFormatter.format(date).replace(".", ""),
      dayNumber: String(date.getDate()).padStart(2, "0"),
      isToday: iso === todayStr,
      bookings: dayBookings,
    });
  }
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu, topbarDate, topbarActionLink, topbarActionLabel }) %>

<% if (error) { %>
  <p class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></p>
<% } %>
<% if (success) { %>
  <p class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= success %></p>
<% } %>

<section class="mb-6 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100">
  <h3 class="mb-3 text-base font-semibold text-slate-900">Semana atual</h3>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-7">
    <% weekDays.forEach((day) => { %>
      <article class="rounded-xl border p-3 transition-all duration-200 <%= day.isToday ? 'border-indigo-500 bg-indigo-50' : 'border-gray-200 bg-white' %>">
        <p class="text-xs font-semibold text-gray-500"><%= day.dayLabel %></p>
        <p class="text-sm font-semibold text-slate-800"><%= day.dayNumber %></p>

        <div class="mt-2 space-y-2">
          <% if (day.bookings.length === 0) { %>
            <p class="text-xs text-gray-400">Livre</p>
          <% } else { %>
            <% day.bookings.forEach((booking) => { const view = statusView(booking.status); %>
              <div class="rounded-lg border border-gray-200 bg-gray-50 px-2 py-1">
                <p class="truncate text-xs font-medium text-slate-700"><%= booking.client_name %></p>
                <p class="text-[11px] text-gray-500"><%= String(booking.start_time).slice(0, 5) %> - <%= String(booking.end_time).slice(0, 5) %></p>
                <span class="mt-1 inline-flex rounded-full px-2 py-0.5 text-[10px] font-semibold <%= view.badge %>"><%= view.label %></span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
  <h3 class="text-lg font-semibold text-slate-900">Reservas de hoje</h3>

  <% if (!bookings || bookings.length === 0) { %>
    <p class="mt-3 text-sm text-gray-500">Nenhuma reserva para hoje</p>
  <% } else { %>
    <ul class="mt-4 space-y-3">
      <% bookings.forEach((booking) => { const view = statusView(booking.status); %>
        <li class="flex flex-col gap-3 rounded-xl border border-gray-100 bg-gray-50 px-4 py-3 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="font-medium text-slate-800"><%= booking.client_name %></p>
            <p class="text-sm text-gray-500">Sala: <%= booking.room_name %></p>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-lg bg-indigo-100 px-3 py-1 text-sm font-semibold text-indigo-700">
              <%= String(booking.start_time).slice(0, 5) %> - <%= String(booking.end_time).slice(0, 5) %>
            </span>
            <span class="rounded-full px-2 py-1 text-xs font-semibold <%= view.badge %>"><%= view.label %></span>
            <% if (booking.status === "confirmed") { %>
              <form method="POST" action="/agenda/<%= booking.id %>/cancelar">
                <button type="submit" class="rounded-md border border-red-200 bg-red-50 px-3 py-1 text-sm text-red-700 transition-all duration-200 hover:bg-red-100">
                  Cancelar
                </button>
              </form>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("../partials/footer") %>
