<%
  const pageTitle = "Nova Reserva";
  const activeMenu = "bookings";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<section class="max-w-3xl rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
  <% if (error) { %>
    <p class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></p>
  <% } %>

  <% if (clients.length === 0 || rooms.length === 0) { %>
    <p class="text-sm text-gray-600">Para criar reserva, cadastre ao menos um cliente e uma sala.</p>
    <p class="mt-2"><a class="text-sm text-blue-700 hover:underline" href="/bookings">Voltar para agenda</a></p>
  <% } else { %>
    <form method="POST" action="/bookings/create" class="grid gap-4 md:grid-cols-2">
      <label class="text-sm text-gray-600">
        Cliente
        <select class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" name="client_id" required>
          <% clients.forEach((client) => { %>
            <option value="<%= client.id %>"><%= client.name %></option>
          <% }) %>
        </select>
      </label>

      <label class="text-sm text-gray-600">
        Sala
        <select class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" name="room_id" required>
          <% rooms.forEach((room) => { %>
            <option value="<%= room.id %>"><%= room.name %></option>
          <% }) %>
        </select>
      </label>

      <label class="text-sm text-gray-600">
        Data
        <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="date" name="date" required />
      </label>

      <label class="text-sm text-gray-600">
        Hora inicio
        <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="time" name="start_time" required />
      </label>

      <label class="text-sm text-gray-600">
        Hora fim
        <input class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" type="time" name="end_time" required />
      </label>

      <div class="mt-2 flex items-center gap-3 md:col-span-2">
        <button class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" type="submit">Salvar</button>
        <a class="text-sm text-gray-600 hover:underline" href="/bookings">Voltar</a>
      </div>
    </form>
  <% } %>
</section>

<%- include("../partials/footer") %>
