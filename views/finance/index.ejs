<%
  const pageTitle = "Financeiro";
  const activeMenu = "finance";
%>
<%- include("../partials/header", { pageTitle }) %>
<%- include("../partials/sidebar", { pageTitle, activeMenu }) %>

<% const canManageFinance = currentUser && (currentUser.role === "admin" || currentUser.role === "manager" || currentUser.role === "funcionario"); %>
<%
  function serviceTypeLabel(value) {
    const labels = {
      monthly_fee: "Mensalidade",
      room_booking: "Reserva de sala",
      coworking_day: "Coworking diario",
      penalty_interest: "Multa/Juros",
      other: "Servico avulso",
    };
    return labels[value] || "-";
  }
%>

<% if (canManageFinance) { %>
  <div class="mb-4 flex justify-end">
    <a class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" href="/finance/create">Nova Cobranca</a>
  </div>
<% } %>

<div class="filter-container mb-4">
    <select id="statusFilter" onchange="filterFinance()">
        <option value="">Todos os Status</option>
        <option value="pago">Pago</option>
        <option value="atrasado">Atrasado</option>
        <option value="pendente">Pendente</option>
    </select>
    <input type="text" id="searchInput" placeholder="Buscar por cliente..." oninput="filterFinance()">
</div>

<section class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-100">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Cliente</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Servico</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Valor</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Vencimento</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Status</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Acoes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% if (invoices.length === 0) { %>
          <tr>
            <td class="px-4 py-4 text-sm text-gray-500" colspan="6">Nenhuma cobranca cadastrada.</td>
          </tr>
        <% } %>

        <% invoices.forEach((invoice) => { %>
          <tr>
            <td class="px-4 py-4">
              <p class="text-sm font-medium text-gray-900"><%= invoice.client_name %></p>
              <p class="mt-0.5 text-xs text-gray-500">Cobrança #<%= invoice.id %></p>
            </td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= serviceTypeLabel(invoice.service_type) %></td>
            <td class="px-4 py-4 text-base font-semibold text-gray-900">R$ <%= Number(invoice.amount || 0).toFixed(2) %></td>
            <td class="px-4 py-4 text-sm text-gray-500"><%= new Date(invoice.due_date).toLocaleDateString("pt-BR") %></td>
            <td class="px-4 py-4">
              <span class="inline-flex rounded-full px-2 py-1 text-xs font-medium tracking-wide <%= invoice.statusClass === 'status-paid' ? 'bg-green-100 text-green-700' : invoice.statusClass === 'status-overdue' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>"><%= invoice.displayStatus.toLowerCase() %></span>
            </td>
            <td class="px-4 py-4">
              <% if (invoice.status !== "paid" && canManageFinance) { %>
                <form method="POST" action="/finance/<%= invoice.id %>/pay">
                  <button class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 transition-all duration-200 hover:border-gray-400 hover:bg-gray-50" type="submit">Marcar como pago</button>
                </form>
              <% } else { %>
                <span class="text-sm text-gray-400">-</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<script>
    function filterFinance() {
        const statusFilter = document.getElementById('statusFilter').value.toLowerCase();
        const searchInput = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('table tbody tr');

        rows.forEach(row => {
            const client = row.querySelector('td:nth-child(1)').textContent.toLowerCase();
            const status = row.querySelector('td:nth-child(5) span').textContent.toLowerCase();

            if (
                (statusFilter === '' || status.includes(statusFilter)) &&
                (client.includes(searchInput))
            ) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>

<style>
    .filter-container {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    #statusFilter, #searchInput {
        padding: 10px;
        border: 2px solid #007bff;
        border-radius: 5px;
        font-size: 16px;
        outline: none;
    }

    #statusFilter:focus, #searchInput:focus {
        border-color: #0056b3;
        box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
    }
</style>

<%- include("../partials/footer") %>
